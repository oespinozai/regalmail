  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "regalmail",
    "openclaw",
    "ai-agent",
    "email",
    "imap",
    "smtp",
    "channel",
