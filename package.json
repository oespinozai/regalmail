{
  "name": "regalmail",
  "version": "0.2.0",
  "description": "Email channel plugin for AI agents — IMAP IDLE inbound + SMTP outbound with Stripe billing, tiers, and usage tracking",
  "homepage": "https://alvento.ltd/email-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/alvento/regalmail"
  },
